{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --filter grand-battle-arena...",
  "buildCommand": "NODE_OPTIONS='--max-old-space-size=3072' pnpm --filter grand-battle-arena run build",
  "outputDirectory": "artifacts/grudge-warlords/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}